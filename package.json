{
  "name": "conversation-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Production-first scaffold for speaker-aware conversation intelligence built around recursive-llm-ts.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev site --host 0.0.0.0",
    "docs:build": "vitepress build site",
    "docs:preview": "vitepress preview site --host 0.0.0.0",
    "analyze:fixture": "tsx examples/analyze-fixture.ts",
    "embedded:fixture": "tsx examples/embedded-runtime.ts",
    "eval:fixtures": "tsx examples/run-fixture-evals.ts",
    "eval:sentiment": "tsx examples/run-sentiment-calibration.ts",
    "eval:sentiment:reviewed": "tsx examples/run-reviewed-sentiment-validation.ts",
    "recommend:sentiment-scoring": "tsx examples/recommend-sentiment-scoring.ts",
    "benchmark:e2e": "tsx examples/run-e2e-benchmark.ts",
    "benchmark:e2e:isolated": "tsx examples/run-e2e-benchmark-isolated.ts",
    "loop:e2e": "tsx examples/run-e2e-improvement-loop.ts",
    "loop:e2e:isolated": "tsx examples/run-e2e-improvement-loop-isolated.ts",
    "loop:e2e:reviewed": "tsx examples/run-reviewed-export-benchmark-loop.ts",
    "loop:e2e:trial-matrix:isolated": "tsx examples/run-e2e-trial-matrix-isolated.ts",
    "build:public-test-pipelines": "tsx examples/build-public-test-pipelines.ts",
    "build:reviewed-benchmark": "tsx examples/build-reviewed-benchmark-dataset.ts",
    "annotate:reviewed-benchmark": "tsx examples/draft-annotate-benchmark-candidates.ts",
    "compare:public-shadow": "tsx examples/compare-public-and-shadow-validation.ts",
    "export:reviewed-runs": "tsx examples/export-reviewed-runs.ts",
    "inspect:reviewed-datasets": "tsx examples/list-reviewed-datasets.ts",
    "refresh:reviewed-runs": "tsx examples/refresh-reviewed-runs.ts",
    "validate:model": "tsx examples/run-model-validation.ts",
    "recommend:validation-thresholds": "tsx examples/recommend-validation-thresholds.ts",
    "apply:validation-thresholds": "tsx examples/apply-validation-thresholds.ts",
    "serve:dev": "tsx examples/start-server.ts",
    "serve:standalone": "tsx examples/start-server.ts",
    "loop:e2e:public-scale:isolated": "tsx examples/run-public-scale-benchmark.ts",
    "loop:e2e:public-reviewed": "tsx examples/run-public-reviewed-benchmark.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "pg": "^8.16.3",
    "recursive-llm-ts": "file:../recursive-llm-ts",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.15.5",
    "pg-mem": "^3.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  }
}
