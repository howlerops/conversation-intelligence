{
  "name": "conversation-intelligence",
  "version": "0.1.0",
  "private": true,
  "description": "Production-first scaffold for speaker-aware conversation intelligence built around recursive-llm-ts.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze:fixture": "tsx examples/analyze-fixture.ts",
    "eval:fixtures": "tsx examples/run-fixture-evals.ts",
    "serve:dev": "tsx examples/start-server.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "recursive-llm-ts": "file:../recursive-llm-ts",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/better-sqlite3": "^7.6.12",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
